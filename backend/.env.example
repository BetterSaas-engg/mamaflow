# API
DATABASE_URL=postgresql://user:password@localhost:5432/mamaflow
SECRET_KEY=your-jwt-secret-key
ALGORITHM=HS256
# Session length (minutes) for the mobile app JWT. 43200 = 30 days (D31): the
# app has no refresh flow, so on expiry the user is signed out and must
# re-authenticate. Update the Railway var too when changing this.
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Google OAuth
GOOGLE_CLIENT_ID=your-google-web-client-id
GOOGLE_CLIENT_SECRET=your-google-web-client-secret
# iOS OAuth client id — used by the mobile PKCE code exchange (no secret; D23).
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Gmail token persistence (D4: tokens never in the DB).
# "memory" = dev default, tokens lost on backend restart (re-sign-in needed).
# "secret-manager" = durable; needs GCP_PROJECT_ID and ADC credentials
# (set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path — never commit it).
TOKEN_STORE_BACKEND=memory
GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Min seconds between completed syncs per user (429 + Retry-After under it).
# Each sync is a full 30-day metadata scan + Claude extraction — cost/DoS guard.
SYNC_COOLDOWN_SECONDS=60

# Push reminders (Track B) — the reminder engine is built but INERT unless
# FIREBASE_CREDENTIALS_JSON is set. Set it to the Firebase service-account JSON
# (one line) to turn on the evening-before digest. A credential — NEVER commit a
# real value, NEVER store in the DB (D4). See docs/track-b-push-activation.md.
# FIREBASE_CREDENTIALS_JSON=
# REMINDER_TZ=America/Toronto
# REMINDER_HOUR must be a WHOLE hour 0-23 (the scheduler ticks at minute :00) —
# "10:30" is invalid. Bad reminder values fall back to defaults with a warning.
# REMINDER_HOUR=18

# Mobile OAuth (D23): the backend code-exchange uses the WEB client above.
# The app additionally needs iOS/Android OAuth client IDs in the same GCP
# project (console setup; not backend env).

# Environment
ENVIRONMENT=development
