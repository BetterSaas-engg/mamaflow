# API
DATABASE_URL=postgresql://user:password@localhost:5432/mamaflow
SECRET_KEY=your-jwt-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe (Phase 2)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Push notifications (FCM) — sender DEFERRED (D27); device registration is live.
# Needed only when the FCM HTTP v1 sender + reminder scheduler are built.
# Point this at the Firebase service-account JSON; NEVER commit the real file.
# FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# FCM_PROJECT_ID=your-firebase-project-id

# Mobile OAuth (D23): the backend code-exchange uses the WEB client above.
# The app additionally needs iOS/Android OAuth client IDs in the same GCP
# project (console setup; not backend env).

# Environment
ENVIRONMENT=development
