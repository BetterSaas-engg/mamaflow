# Environment
.env
.env.*
!**/.env.example

# AI assistant: personal/local overrides (do NOT commit)
.claude/settings.local.json
CLAUDE.local.md
*.local.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node / frontend (platform TBD — see DECISIONS.md; add framework-specific ignores when chosen)
node_modules/

# Secrets (also blocked by firewall-guard) — artifact-scoped, NOT a broad *token* (keeps token_store.py)
*.pem
*.key
*.token
credentials.json
token.json
**/credentials.json
**/token.json
**/secrets/

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
terraform.tfvars
*.auto.tfvars
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Flutter / Dart (frontend)
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/build/
frontend/.pub-cache/
frontend/.pub/
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/**/GeneratedPluginRegistrant.*
# Firebase / platform config = treat as secrets, never commit
frontend/**/google-services.json
frontend/**/GoogleService-Info.plist
frontend/android/key.properties
frontend/**/*.keystore

# Visual brainstorming companion (mockups, ephemeral)
.superpowers/
