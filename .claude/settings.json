{
  "description": "Mamaflow project settings — firewall enforcement + safe permissions",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/scripts/firewall-hook.sh",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/scripts/firewall-guard.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(./**/*.token)",
      "Read(./**/token.json)",
      "Read(./**/credentials.json)",
      "Read(./**/.env)",
      "Read(./**/secrets/**)"
    ]
  }
}
